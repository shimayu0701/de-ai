{
  "name": "de-ai",
  "version": "0.1.0",
  "description": "Remove AI-generated look from websites. Restore human touch. / AIらしさを除去して、人間らしいウェブを取り戻す。",
  "bin": {
    "de-ai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "design", "css", "html", "japanese", "web-design", "refactor"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "openai": "^4.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
